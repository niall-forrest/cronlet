PORT=4050
HOST=0.0.0.0
CLOUD_STORE_MODE=prisma
# Optional in local dev (defaults to "dev-internal-token"); required in production.
CLOUD_INTERNAL_TOKEN=replace-me
# Comma-separated. If omitted, local localhost/127.0.0.1 origins are allowed by default.
CLOUD_WEB_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cronlet_cloud
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_WEBHOOK_SECRET=
CLERK_BILLING_FREE_PLAN_KEYS=free,free_user
CLERK_BILLING_PRO_PLAN_KEYS=pro,cronlet_pro
CLERK_BILLING_TEAM_PLAN_KEYS=team,cronlet_team
