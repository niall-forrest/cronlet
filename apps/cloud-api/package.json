{
  "name": "@cronlet/cloud-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "set -a; [ -f .env ] && . ./.env; set +a; tsx watch src/index.ts",
    "build": "prisma generate && tsup",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^5.22.0",
    "@cronlet/shared": "workspace:*",
    "croner": "^8.1.2",
    "fastify": "^4.28.1",
    "fastify-raw-body": "^4.3.0",
    "jose": "^5.9.6",
    "svix": "^1.59.0",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "@cronlet/eslint-config": "workspace:*",
    "@types/node": "^20.0.0",
    "prisma": "^5.22.0",
    "tsup": "^8.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  }
}
