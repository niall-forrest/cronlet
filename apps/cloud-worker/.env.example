CLOUD_API_BASE_URL=http://127.0.0.1:4050
# Optional in local dev (defaults to "dev-internal-token"); required in production.
CLOUD_INTERNAL_TOKEN=replace-me
# Optional in local dev (defaults to redis://127.0.0.1:6379); required in production.
REDIS_URL=redis://localhost:6379
CLOUD_POLL_INTERVAL_MS=15000
CLOUD_DISPATCH_QUEUE_NAME=cronlet-cloud-dispatch
