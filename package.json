{
  "name": "cronlet-monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "docs:build": "pnpm --filter @cronlet/docs build",
    "docs:smoke": "node scripts/smoke/docs-site.mjs",
    "test:fixtures": "node scripts/smoke/cli-fixtures.mjs",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck",
    "release:check": "pnpm build && pnpm test && pnpm typecheck && pnpm test:fixtures && pnpm docs:smoke",
    "cronlet": "node packages/cronlet-cli/dist/cli.js"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  }
}
