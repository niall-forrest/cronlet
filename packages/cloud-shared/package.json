{
  "name": "@cronlet/shared",
  "version": "0.1.0",
  "description": "Shared types and schemas for Cronlet Cloud",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "keywords": [
    "cronlet",
    "types",
    "schemas"
  ],
  "author": "Cronlet",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cronlet/cronlet",
    "directory": "packages/cloud-shared"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@cronlet/eslint-config": "workspace:*",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
